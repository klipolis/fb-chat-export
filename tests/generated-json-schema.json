{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Messenger Chat Export Preview",
  "type": "object",
  "required": ["html_locale", "title", "type", "data_raw", "data_preview"],
  "properties": {
    "html_locale": { "type": ["string", "null"] },
    "title": { "type": "string" },
    "type": { "type": "string" },
    "data_raw": {
      "type": "object",
      "required": ["date", "name", "content", "duration", "length"],
      "properties": {
        "date": { "type": ["string", "null"] },
        "name": { "type": ["string", "null"] },
        "content": { "type": ["string", "null"] },
        "duration": { "type": ["string", "null"] },
        "length": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "data_preview": {
      "type": "object",
      "required": ["date", "name", "content", "duration", "length"],
      "properties": {
        "date": { "type": "string" },
        "name": { "type": ["string", "null"] },
        "content": { "type": ["string", "null"] },
        "duration": { "type": ["string", "null"] },
        "length": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
