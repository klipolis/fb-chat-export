# Auto-detect text files and normalize line endings
* text=auto

# Generated outputs — build writes LF; don't let autocrlf convert on checkout
[data-output-auto/**]
text eol=lf

# Force LF for source and documentation files
*.js text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# Preserve line endings for Windows shell scripts
*.ps1 text eol=crlf
*.bat text eol=crlf

# Treat binary files as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
