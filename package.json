    "build:ci:frontend": "CI=true pnpm run build:frontend"
  },
  "engines": {
    "node": "^26.1.0",
    "pnpm": ">=8.10.0"
  },
  "devDependencies": {
    "esbuild": "^0.19.4"
  }
}
