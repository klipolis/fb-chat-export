{
  "name": "fb-chat-exporter",
  "version": "5.0.0",
  "private": true,
  "packageManager": "pnpm@8.10.0",
  "scripts": {
    "build:server": "node src/build-server.js",
    "build:frontend": "node src/build-frontend.js",
    "build:preview": "node src/server/build-preview.js",
    "create:nodes": "node src/shared/create-nodes.js",
    "test": "node tests/run-tests.js",
    "build": "pnpm run build:server && pnpm run build:frontend",
