{
  "name": "fb-chat-exporter",
  "version": "5.4.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "build:server": "node src/build-server.js",
    "build:raw": "cross-env BUILD_RAW=true node src/build-server.js",
    "build:raw-clean": "node src/build-raw-clean.js",
    "build:frontend": "node src/build.js",
    "build:preview": "node src/server/build-preview.js",
    "build:clean": "node src/build-clean.js",
    "create:nodes": "node src/shared/create-nodes.js",
    "validate:generated-json": "node tests/validate-generated-json.js",
    "validate:generated-txt": "node tests/validate-generated-txt.js",
    "validate:dist": "node tests/validate-dist.js",
    "validate:golden": "node tests/validate-golden.js",
    "validate:release": "node tests/validate-release.js",
    "test:unit": "tap --timeout 20000 tests/run-tests.js tests/test-ui.js",
    "test": "pnpm run lint && pnpm run test:unit && pnpm run validate:generated-json && pnpm run validate:generated-txt && pnpm run validate:dist && pnpm run validate:golden && pnpm run validate:release",
    "lint": "eslint --quiet \"src/**/*.js\" \"tests/**/*.js\"",
    "lint:changelog": "node scripts/lint-changelog.js",
    "lint:commits": "commitlint --from HEAD~10 --to HEAD --verbose",
    "check:unreleased": "node scripts/check-unreleased.js",
    "release": "node scripts/do-release.js",
    "lint:docs": "markdownlint --config .markdownlint.json \"docs/**/*.md\" \"README.md\" \"CHANGELOG.md\" \"*.md\"",
    "link:docs": "node scripts/check-doc-links.js",
    "check:license": "node scripts/check-license.js",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" \"docs/**/*.md\" \"README.md\" \"CHANGELOG.md\" \"CONTRIBUTING.md\" \"SECURITY.md\" \"CODE_OF_CONDUCT.md\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\" \"docs/**/*.md\" \"README.md\" \"CHANGELOG.md\" \"CONTRIBUTING.md\" \"SECURITY.md\" \"CODE_OF_CONDUCT.md\"",
    "audit": "pnpm audit --audit-level=moderate",
    "release:check": "pnpm run validate:release",
    "release:tag": "pnpm run release:check && node -e \"require('child_process').execSync('git tag v'+require('./package.json').version,{stdio:'inherit'})\"",
    "build": "pnpm run build:server && pnpm run build:frontend",
    "build:ci": "cross-env CI=true pnpm run lint && pnpm run lint:changelog && pnpm run check:license && pnpm run audit && cross-env CI=true pnpm run build && pnpm run test",
    "build:ci:server": "cross-env CI=true pnpm run build:server",
    "build:ci:frontend": "cross-env CI=true pnpm run build:frontend",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=26.0.0",
    "pnpm": ">=11.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.0",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.0.0",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "markdown-link-check": "^3.14.2",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.8.3",
    "tap": "^21.7.4"
  }
}
