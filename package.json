{
  "name": "fb-chat-exporter",
  "version": "5.0.0",
  "private": true,
  "packageManager": "pnpm@8.10.0",
  "scripts": {
    "build:server": "node src/build-server.js",
    "build:frontend": "node src/build-frontend.js",
    "build:preview": "node src/server/build-preview.js",
    "build:clean": "node src/build-clean.js",
    "create:nodes": "node src/shared/create-nodes.js",
    "validate:generated-json": "node tests/validate-generated-json.js",
    "validate:generated-txt": "node tests/validate-generated-txt.js",
    "test": "node tests/run-tests.js && pnpm run validate:generated-json && pnpm run validate:generated-txt",
    "lint": "pnpm run test",
    "build": "pnpm run build:server && pnpm run build:frontend && pnpm run test",
    "build:ci": "CI=true pnpm run build",
    "build:ci:server": "CI=true pnpm run build:server",
    "build:ci:frontend": "CI=true pnpm run build:frontend"
  },
  "engines": {
    "node": "^26.1.0",
    "pnpm": ">=8.10.0"
  },
  "devDependencies": {
    "esbuild": "^0.19.4",
    "jsdom": "^22.1.0"
  }
}
